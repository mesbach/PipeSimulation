<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="Water_Flow_Simulation_v1.MainWindow"
        Title="Liquid Flow Simulation v1" Height="605" Width="1274" Background="White" ResizeMode="NoResize" WindowStyle="ThreeDBorderWindow">
    <Grid>
    	<Grid.Background>
    		<SolidColorBrush Color="{DynamicResource {x:Static SystemColors.InactiveCaptionColorKey}}"/>
    	</Grid.Background>
    	<Grid.ColumnDefinitions>
    		<ColumnDefinition Width="0.203*"/>
    		<ColumnDefinition Width="0.797*"/>
    	</Grid.ColumnDefinitions>
        <Grid Margin="-8.312,34,8,4.562" Background="#FF8C8E94" Grid.Column="1"/>
        <TabControl x:Name="tabControl1" VerticalAlignment="Top" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="6,12,10,0" Height="557">
        	<TabControl.Background>
        		<SolidColorBrush Color="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionColorKey}}"/>
        	</TabControl.Background>
            <TabItem Header="ToolBox" x:Name="tabItem1">
                <Grid HorizontalAlignment="Left">
                    <Button Content="titik Acu" Height="22" HorizontalAlignment="Left" Margin="3.998,91.66,0,0" x:Name="button1" VerticalAlignment="Top" Width="68" Click="button1_Click" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" />
                    <Button Height="23" Margin="75.998,90.66,106.002,0" x:Name="button2" VerticalAlignment="Top" Click="button2_Click" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" Content="hapus"/>
                    <Button Content="awal" Height="23" HorizontalAlignment="Left" Margin="181.998,90.66,0,0" x:Name="awal" VerticalAlignment="Top" Width="46" Click="awal_Click" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}"/>
                    <Button Content="akhir" Height="23" HorizontalAlignment="Left" Margin="129.998,90.66,0,0" x:Name="akhir" VerticalAlignment="Top" Width="48" Click="akhir_Click" RenderTransformOrigin="0,0.4" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" />
                    <Button Height="22" Margin="3.998,118.66,4.002,0" x:Name="button4" VerticalAlignment="Top" Click="button4_Click" Background="#FFCAD6F3" Content="Kalkulasi"/>
                    <GroupBox Header="Properties" Height="262.342" HorizontalAlignment="Left" Margin="0,141.325,0,0" x:Name="groupBox1" VerticalAlignment="Top" Width="232">
                        <Grid>
                            <Label Content="Diameter" Height="28" HorizontalAlignment="Left" Margin="8,33.646,0,0" x:Name="label1" VerticalAlignment="Top" />
                            <TextBox Height="23" HorizontalAlignment="Left" Margin="132,33.646,0,0" x:Name="diameter" VerticalAlignment="Top" Width="75" />
                            <TextBox Height="23" HorizontalAlignment="Left" Margin="132,62.646,0,0" x:Name="diemater2" VerticalAlignment="Top" Width="75" />
                            <TextBox Height="23" HorizontalAlignment="Left" Margin="132,91.646,0,0" x:Name="debit" VerticalAlignment="Top" Width="75" />
                            <TextBox Height="23" HorizontalAlignment="Left" Margin="132,120.646,0,0" x:Name="radius" VerticalAlignment="Top" Width="75" />
                            <TextBox Height="23" HorizontalAlignment="Left" Margin="132,149.646,0,0" x:Name="sudutpengecilan" VerticalAlignment="Top" Width="75" />
                            <TextBox Height="23" HorizontalAlignment="Left" Margin="132,178.646,0,0" x:Name="sudutpembesaran" VerticalAlignment="Top" Width="75" />
                            <Label Content="Diameter 2" Height="28" HorizontalAlignment="Left" Margin="8,62.646,0,0" x:Name="label2" VerticalAlignment="Top" />
                            <Label Content="Debit" Height="28" HorizontalAlignment="Left" Margin="8,91.646,0,0" x:Name="label3" VerticalAlignment="Top" />
                            <Label Content="Radius" Height="28" HorizontalAlignment="Left" Margin="8,120.646,0,0" x:Name="label4" VerticalAlignment="Top" />
                            <Label Content="Sudut Pengecilan" Height="28" HorizontalAlignment="Left" Margin="8,149.646,0,0" x:Name="label5" VerticalAlignment="Top" />
                            <Label Content="Sudut Pembesaran" Height="28" HorizontalAlignment="Left" Margin="9,178.646,0,0" x:Name="label6" VerticalAlignment="Top" />
                            <Button Content="OK" Height="23" HorizontalAlignment="Left" Margin="132,208.646,0,0" x:Name="button3" VerticalAlignment="Top" Width="75" Click="button3_Click" />
                            <Label Height="33.646" Margin="9,0,13,0" x:Name="namaPipa" VerticalAlignment="Top" FontWeight="Bold" />
                        </Grid>
                    </GroupBox>
                    <GroupBox Header="Daftar Pipa" Height="81" HorizontalAlignment="Left" Margin="0,6,0,0" x:Name="groupBox2" VerticalAlignment="Top" Width="232">
                        <Grid>
                            <Button Height="23" HorizontalAlignment="Left" Margin="12,18,0,0" x:Name="lurus" VerticalAlignment="Top" Width="28" Click="lurus_Click">
                                <Button.Background>
                                    <ImageBrush ImageSource="/Water%20Flow%20Simulation%20v1;component/Images/Lurus.png" Stretch="UniformToFill" />
                                </Button.Background>
                            </Button>
                            <Button Height="23" HorizontalAlignment="Left" Margin="46,18,0,0" x:Name="belok" VerticalAlignment="Top" Width="28" Click="belok_Click">
                                <Button.Background>
                                    <ImageBrush ImageSource="/Water%20Flow%20Simulation%20v1;component/Images/belok.png" />
                                </Button.Background>
                            </Button>
                            <Button Height="23" HorizontalAlignment="Left" Margin="80,18,0,0" x:Name="abesar" VerticalAlignment="Top" Width="28" Click="abesar_Click">
                                <Button.Background>
                                    <ImageBrush ImageSource="/Water%20Flow%20Simulation%20v1;component/Images/kecilBesarAngsur.png" />
                                </Button.Background>
                            </Button>
                            <Button Height="23" HorizontalAlignment="Left" Margin="114,18,0,0" x:Name="akecil" VerticalAlignment="Top" Width="28" Click="akecil_Click">
                                <Button.Background>
                                    <ImageBrush ImageSource="/Water%20Flow%20Simulation%20v1;component/Images/besarKecilAngsur.png" />
                                </Button.Background>
                            </Button>
                            <Button Height="23" HorizontalAlignment="Left" Margin="148,18,0,0" x:Name="tbesar" VerticalAlignment="Top" Width="28" Click="tbesar_Click">
                                <Button.Background>
                                    <ImageBrush ImageSource="/Water%20Flow%20Simulation%20v1;component/Images/kecilBesarTiba.png" />
                                </Button.Background>
                            </Button>
                            <Button Height="23" HorizontalAlignment="Left" Margin="182,18,0,0" x:Name="tkecil" VerticalAlignment="Top" Width="28" Click="tkecil_Click">
                                <Button.Background>
                                    <ImageBrush ImageSource="/Water%20Flow%20Simulation%20v1;component/Images/besarKecilTiba.png" />
                                </Button.Background>
                            </Button>
                        </Grid>
                    </GroupBox>
                    <Image Height="117.373" Margin="15.667,0,13.333,0" Source="Images/Logo_its.png" Stretch="Fill" VerticalAlignment="Bottom" ClipToBounds="True" SnapsToDevicePixels="True"/>
                </Grid>
            </TabItem>
        </TabControl>
        <Canvas Margin="-7.572,34.938,8.917,5.292" x:Name="canvas1" VerticalAlignment="Stretch" Background="White" MouseDown="canvas1_MouseDown" ClipToBounds="True" SnapsToDevicePixels="True" RenderTransformOrigin="0.5,0.5" Grid.Column="1">
        	<Canvas.RenderTransform>
        		<TransformGroup>
        			<ScaleTransform ScaleY="-1" ScaleX="1"/>
        			<SkewTransform AngleY="0" AngleX="0"/>
        			<RotateTransform Angle="0"/>
        			<TranslateTransform/>
        		</TransformGroup>
        	</Canvas.RenderTransform>
        </Canvas>
    </Grid>
</Window>
